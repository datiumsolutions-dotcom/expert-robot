{
  "name": "loyalty-saas",
  "version": "0.0.1",
  "private": true,
  "description": "Loyalty SaaS for Restaurants — Monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "pnpm --recursive --filter './apps/*' test",
    "db:generate": "pnpm --filter @loyalty/db generate",
    "db:migrate": "pnpm --filter @loyalty/db migrate:dev",
    "db:migrate:prod": "pnpm --filter @loyalty/db migrate:deploy"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
