# Docker-specific environment overrides
# These complement docker-compose.yml service env declarations
# Copy to .env.docker and fill in real values

# ─── JWT (RS256) — generate with:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPLACEHOLDER_REPLACE_IN_PRODUCTION\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPLACEHOLDER_REPLACE_IN_PRODUCTION\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ─── S3 / MinIO
S3_BUCKET=loyalty-uploads
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─── CORS
CORS_ORIGIN=http://localhost:3000
